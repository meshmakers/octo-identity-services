<Project Sdk="Microsoft.NET.Sdk">
    
    <PropertyGroup>
        <OctoSkipCkCompile Condition="'$(Configuration)'=='Release'">true</OctoSkipCkCompile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Meshmakers.Octo.ConstructionKit.SourceGeneration" OutputItemType="Analyzer" ReferenceOutputAssembly="false" Version="3.0.1" PrivateAssets="all" />
        <PackageReference Include="Meshmakers.Octo.Runtime.Contracts" Version="3.0.1" />
    </ItemGroup>

    <ItemGroup>
        <None Remove="ConstructionKit\ck-*.yaml"/>
        <EmbeddedResource Include="ConstructionKit\ck-*.yaml">
            <GenerateCkModelServiceClass>true</GenerateCkModelServiceClass>
        </EmbeddedResource>
        <None Remove="ConstructionKit\ck-*.cache.json"/>
        <AdditionalFiles Include="ConstructionKit\ck-*.cache.json"/>
    </ItemGroup>
</Project>
