      <_ContentIncludedByDefault Remove="test\keys\is-signing-key-B57A3203657D6980977B949DF4C2EF06.json" />
      <_ContentIncludedByDefault Remove="test\keys\is-signing-key-F5DD0338263D2C43B50351656440805F.json" />
      <_ContentIncludedByDefault Remove="test\Meshmakers.Octo.Backend.IdentityServices.deps.json" />
      <_ContentIncludedByDefault Remove="test\Meshmakers.Octo.Backend.IdentityServices.runtimeconfig.json" />
      <_ContentIncludedByDefault Remove="test\package-lock.json" />
      <_ContentIncludedByDefault Remove="test\package.json" />
    </ItemGroup>

</Project>