{
  "name": "identity-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node aspnetcore-https",
    "start": "ng serve --port 44400 --host=0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "extract-i18n": "ng extract-i18n",
    "postinstall": "node -e \"var s=require('path').join(__dirname,'src/environments/version.ts');require('fs').existsSync(s)?require('child_process').execSync('node \\\"'+s+'\\\"',{stdio:'inherit'}):console.log('Version generation skipped')\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@progress/kendo-angular-buttons": "^23.1.0",
    "@progress/kendo-angular-inputs": "^23.1.0",
    "@progress/kendo-angular-layout": "^23.1.0",
    "@progress/kendo-angular-icons": "^23.1.0",
    "@progress/kendo-angular-l10n": "^23.1.0",
    "@progress/kendo-angular-common": "^23.1.0",
    "@progress/kendo-angular-popup": "^23.1.0",
    "@progress/kendo-licensing": "^1.10.1",
    "@progress/kendo-theme-default": "^13.0.1",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@types/node": "^25.3.0",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.50.0"
  }
}
