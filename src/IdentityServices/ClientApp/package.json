{
  "name": "identity-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node aspnetcore-https",
    "start": "ng serve --port 44400 --host=0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "extract-i18n": "ng extract-i18n",
    "postinstall": "node -e \"var s=require('path').join(__dirname,'src/environments/version.ts');require('fs').existsSync(s)?require('child_process').execSync('node \\\"'+s+'\\\"',{stdio:'inherit'}):console.log('Version generation skipped')\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@progress/kendo-angular-buttons": "^24.1.0",
    "@progress/kendo-angular-inputs": "^24.1.0",
    "@progress/kendo-angular-layout": "^24.1.0",
    "@progress/kendo-angular-icons": "^24.1.0",
    "@progress/kendo-angular-l10n": "^24.1.0",
    "@progress/kendo-angular-common": "^24.1.0",
    "@progress/kendo-angular-popup": "^24.1.0",
    "@progress/kendo-licensing": "^1.11.0",
    "@progress/kendo-theme-default": "^13.1.0",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "overrides": {
    "undici": "^7.24.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "angular-eslint": "22.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
