@model Meshmakers.Octo.Backend.IdentityServices.ViewModels.Account.LoggedOutViewModel
@{
    // set this so the layout rendering sees an anonymous user
    ViewData["signed-out"] = true;
    ViewData["Title"] = IdentityTexts.Backend_Identity_LoggedOut_Title;
    Layout = "_LayoutNoNavigation";
}

<div class="row justify-content-center">
    <div class="mdc-card col-sm-4">
        <div class=" octo-card-content">

            <div class="octo-card__primary">
                <h1 class="octo-card__title mdc-typography mdc-typography--headline1">@IdentityTexts.Backend_Identity_LoggedOut_Title</h1>
            </div>

            <div class="mdc-card__content">
                <p>@string.Format(IdentityTexts.Backend_Identity_LoggedOut_LoggedOutMessage, OemOptions.Value.ApplicationName)</p>
            </div>
            <div class="mdc-card__actions">
                @if (Model.PostLogoutRedirectUri != null)
                {
                    <a class="redirect-url mdc-button mdc-button--raised mdc-button mdc-card__action mdc-card__action--button"
                       href="@Model.PostLogoutRedirectUri">
                        @string.Format(IdentityTexts.Backend_Identity_LoggedOut_RedirectMessage, Model.ClientName)
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.SignOutIframeUrl != null)
{
    <iframe width="0" height="0" src="@Model.SignOutIframeUrl"></iframe>
}

@section scripts
{
    @if (Model.AutomaticRedirectAfterSignOut)
    {
        <script src="~/js/redirect.js"></script>
    }
}