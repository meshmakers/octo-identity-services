@using Meshmakers.Octo.Backend.IdentityServices.Configuration
@model Meshmakers.Octo.Backend.IdentityServices.ViewModels.Account.LoginViewModel
@inject IOptions<EmailInteractionConfiguration> EmailOptions;
@inject IOptions<OemOptions> OemOptions;

@{
    ViewBag.Title = IdentityTexts.Backend_Identity_Login_Title;
    Layout = OemOptions.Value.HideNavigation ? "_LayoutNoNavigation" : "_Layout";
}

<div class="row justify-content-center">
    <div class="col-sm-8 col-lg-6 col-xl-4">
        <h1>@IdentityTexts.Backend_Identity_Login_Title</h1>
    </div>
</div>

<partial name="_ValidationSummary"/>


@if (Model.EnableLocalLogin)
{
    <div class="row justify-content-center">

        <div class="col-sm-8 col-lg-6 col-xl-4">
            <form asp-route="Login">
                <input type="hidden" asp-for="ReturnUrl"/>

                <div class="mdc-card">
                    <div class=" octo-card-content">

                        <div class="octo-card__primary">
                            <h5 class="octo-card__title mdc-typography mdc-typography--headline5">@IdentityTexts.Backend_Identity_Login_Local</h5>
                        </div>

                        <div class="mdc-card__content">
                            <fieldset>
                                <div class="form-group octo-input-group">
                                    <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                        <span class="mdc-notched-outline">
                                            <span class="mdc-notched-outline__leading"></span>
                                            <span class="mdc-notched-outline__notch">
                                                <span class="mdc-floating-label" id="username">@IdentityTexts.Backend_Identity_Login_Email_Label</span>
                                            </span>
                                            <span class="mdc-notched-outline__trailing"></span>
                                        </span>
                                        <input type="text" class="mdc-text-field__input" name="username" id="username" aria-labelledby="username">
                                    </label>
                                    <span asp-validation-for="Username" class="octo-validation-error"></span>
                                </div>
                                <div class="form-group octo-input-group">
                                    <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                        <span class="mdc-notched-outline">
                                            <span class="mdc-notched-outline__leading"></span>
                                            <span class="mdc-notched-outline__notch">
                                                <span class="mdc-floating-label" id="password">@IdentityTexts.Backend_Identity_Login_Password_Label</span>
                                            </span>
                                            <span class="mdc-notched-outline__trailing"></span>
                                        </span>
                                        <input type="password" class="mdc-text-field__input" name="password" id="password" autocomplete="off" aria-labelledby="password">
                                    </label>
                                    <span asp-validation-for="Password" class="octo-validation-error"></span>
                                </div>
                                @if (EmailOptions.Value.EnableEmailNotifications)
                                {
                                    <div>
                                        <a class="nav-link"
                                           asp-controller="Account"
                                           asp-action="ForgotPassword">
                                            @IdentityTexts.Backend_Identity_Forgot_Password_Link
                                        </a>
                                    </div>
                                }

                                @if (Model.AllowRememberLogin)
                                {
                                    <div class="mdc-form-field">
                                        <div class="mdc-checkbox">
                                            <input type="checkbox"
                                                   class="mdc-checkbox__native-control"
                                                   id="cb-remember" asp-for="RememberLogin"/>
                                            <div class="mdc-checkbox__background">
                                                <svg class="mdc-checkbox__checkmark"
                                                     viewBox="0 0 24 24">
                                                    <path class="mdc-checkbox__checkmark-path"
                                                          fill="none"
                                                          d="M1.73,12.91 8.1,19.28 22.79,4.59"/>
                                                </svg>
                                                <div class="mdc-checkbox__mixedmark"></div>
                                            </div>
                                            <div class="mdc-checkbox__ripple"></div>
                                        </div>
                                        <label for="cb-remember" class="octo-label">@IdentityTexts.Backend_Identity_Login_RememberMe_Label</label>
                                    </div>
                                }
                            </fieldset>


                        </div>

                        <div class="mdc-card__actions">

                            <button class="mdc-button mdc-button--raised mdc-card__action mdc-card__action--button" name="button" type="submit" value="login">
                                @IdentityTexts.Backend_Identity_Login_Login_Button
                            </button>

                            <button class="mdc-button mdc-button--outlined mdc-card__action mdc-card__action--button" name="cancel" type="submit" value="cancel">
                                @IdentityTexts.Backend_Identity_Login_Cancel_Button
                            </button>
                        </div>
                    </div>
                </div>

            </form>

        </div>
    </div>
}

@if (Model.VisibleExternalProviders != null && Model.VisibleExternalProviders.Any())
{
    <div class="row justify-content-center pt-4">
        <div class="col-sm-4">
            <div class="mdc-card">
                <div class=" octo-card-content">

                    <div class="octo-card__primary">
                        <p class="octo-card__title mdc-typography mdc-typography--headline6">@IdentityTexts.Backend_Identity_Login_External</p>
                    </div>

                    <div class="mdc-card__content">
                        @foreach (var provider in Model.VisibleExternalProviders)
                        {
                            <a class="mdc-button mdc-button--raised mdc-button mdc-card__action mdc-card__action--button m-2"
                               asp-controller="External"
                               asp-action="Challenge"
                               asp-route-provider="@provider.AuthenticationScheme"
                               asp-route-returnUrl="@Model.ReturnUrl">
                                @provider.DisplayName
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (!Model.EnableLocalLogin && Model.VisibleExternalProviders != null && !Model.VisibleExternalProviders.Any())
{
    <div class="alert alert-warning">
        <strong>@IdentityTexts.Backend_Identity_Login_Error_InvalidClient_Title</strong>
        @IdentityTexts.Backend_Identity_Login_Error_InvalidClient_Body
    </div>
}