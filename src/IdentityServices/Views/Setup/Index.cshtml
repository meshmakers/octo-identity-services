@model Meshmakers.Octo.Backend.IdentityServices.ViewModels.Setup.SetupViewModel
@{
    ViewData["Title"] = IdentityTexts.Backend_Identity_Setup_Title;
}

<div class="row justify-content-center">
    <div class="col-auto text-center">
        <h1>@IdentityTexts.Backend_Identity_Setup_Title</h1>
    </div>
</div>
<div class="row justify-content-center">
    <div class="col-auto text-center">
        <p>@IdentityTexts.Backend_Identity_Setup_Subtitle</p>
    </div>
</div>


<partial name="_ValidationSummary"/>

<div class="row justify-content-center">

    <div class="col-sm-4">
        <form asp-route="Login">

            <div class="mdc-card">
                <div class=" octo-card-content">

                    <div class="mdc-card__content">

                        <fieldset>
                            <div class="form-group octo-input-group">
                                <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                    <span class="mdc-notched-outline">
                                        <span class="mdc-notched-outline__leading"></span>
                                        <span class="mdc-notched-outline__notch">
                                            <span class="mdc-floating-label" id="EMailAddress">@IdentityTexts.Backend_Identity_Login_Email_Label</span>
                                        </span>
                                        <span class="mdc-notched-outline__trailing"></span>
                                    </span>
                                    <input type="text" class="mdc-text-field__input" name="EMailAddress" id="EMailAddress" aria-labelledby="EMailAddress">
                                </label>
                                <span asp-validation-for="EMailAddress" class="sg-validation-error"></span>
                            </div>
                            <div class="form-group octo-input-group">
                                <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                    <span class="mdc-notched-outline">
                                        <span class="mdc-notched-outline__leading"></span>
                                        <span class="mdc-notched-outline__notch">
                                            <span class="mdc-floating-label" id="NewPassword">@IdentityTexts.Backend_Identity_NewPassword_Label</span>
                                        </span>
                                        <span class="mdc-notched-outline__trailing"></span>
                                    </span>
                                    <input type="password" class="mdc-text-field__input" name="NewPassword" id="NewPassword" autocomplete="off" aria-labelledby="NewPassword">
                                </label>
                                <span asp-validation-for="NewPassword" class="sg-validation-error"></span>
                            </div>
                            <div class="form-group octo-input-group">
                                <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                    <span class="mdc-notched-outline">
                                        <span class="mdc-notched-outline__leading"></span>
                                        <span class="mdc-notched-outline__notch">
                                            <span class="mdc-floating-label" id="ConfirmPassword">@IdentityTexts.Backend_Identity_ConfirmNewPassword_Label</span>
                                        </span>
                                        <span class="mdc-notched-outline__trailing"></span>
                                    </span>
                                    <input type="password" class="mdc-text-field__input" name="ConfirmPassword" id="ConfirmPassword" autocomplete="off" aria-labelledby="ConfirmPassword">
                                </label>
                                <span asp-validation-for="ConfirmPassword" class="sg-validation-error"></span>
                            </div>
                        </fieldset>


                    </div>
                    <div class="mdc-card__actions">
                        <button class="mdc-button mdc-button--raised mdc-button mdc-card__action mdc-card__action--button" name="button" type="submit" value="login">
                            @IdentityTexts.Backend_Identity_Setup_Create_Button
                        </button>
                    </div>
                </div>
            </div>

        </form>

    </div>
</div>