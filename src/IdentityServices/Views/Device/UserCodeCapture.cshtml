@model Meshmakers.Octo.Backend.IdentityServices.ViewModels.Device.DeviceUserCodeCaptureViewModel

@{
    ViewBag.Title = IdentityTexts.Backend_Identity_Device_Authorize_Title;
}

<div class="row justify-content-center">
    <div class="col-auto text-center">
        <h1>@IdentityTexts.Backend_Identity_Device_Authorize_Title</h1>
    </div>
</div>


<div class="row justify-content-center">
    <div class="col-sm-4">
        <form asp-action="UserCodeCapture" method="post">

            <div class="mdc-card">
                <div class=" octo-card-content">

                    <div class="octo-card__primary">
                        <h5 class="octo-card__title mdc-typography mdc-typography--headline5">@IdentityTexts.Backend_Identity_Device_Authorize_Subtitle</h5>
                    </div>

                    <div class="mdc-card__content">


                        <fieldset>
                            <div class="form-group">
                                <label class="mdc-text-field octo-login-input mdc-text-field--outlined">
                                    <span class="mdc-notched-outline">
                                        <span class="mdc-notched-outline__leading"></span>
                                        <span class="mdc-notched-outline__notch">
                                            <span class="mdc-floating-label" id="UserCode">@IdentityTexts.Backend_Identity_UserCode_Header</span>
                                        </span>
                                        <span class="mdc-notched-outline__trailing"></span>
                                    </span>
                                    <input type="text" class="mdc-text-field__input" autofocus name="UserCode" id="UserCode" aria-labelledby="username">
                                </label>
                                <span asp-validation-for="UserCode" class="octo-validation-error"></span>
                            </div>
                        </fieldset>
                    </div>
                    <div class="mdc-card__actions">
                        <button type="submit" class="mdc-button mdc-button--raised mdc-button mdc-card__action mdc-card__action--button">@IdentityTexts.Backend_General_Submit_Header</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>